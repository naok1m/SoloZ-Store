# Local PostgreSQL
# DATABASE_URL=postgresql://postgres:admin@localhost:5432/soloz

# Supabase (transaction pooler for app runtime)
# Replace [YOUR-PASSWORD], [PROJECT-REF]
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Supabase (direct connection for Prisma migrations)
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
JWT_SECRET=change-me
MP_ACCESS_TOKEN=your-mercadopago-access-token
RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PASSWORD=your-rcon-password
PORT=4000
WEBHOOK_TOKEN=your-webhook-token
